# Chạy MÁY LOCAL (profile dev) — copy thành .env khi dev, KHÔNG upload lên Render
# Hoặc trên Render dùng .env đầy đủ có SPRING_PROFILES_ACTIVE=prod

# Xóa hoặc comment 2 dòng prod nếu muốn fallback MySQL 127.0.0.1:3307:
# SPRING_PROFILES_ACTIVE=prod
# AIVEN_CA_CERT_PATH=ca.pem

AIVEN_DB_PASSWORD=
JWT_SECRET=TravelVietBookingJwtSecretKey2026-Min32Chars-Ok!
GEMINI_API_KEY=
WEATHERAPI_KEY=

# Chỉ dev local: Render/API public không lên → backend khuyến nghị http://localhost:8088/api/v1
API_FAILOVER_ENABLED=true
API_PREFER_PUBLIC=true
APP_API_LOCAL_BASE_URL=http://localhost:8088/api/v1

# Chỉ MySQL local (không Aiven): để trống AIVEN_DB_PASSWORD hoặc DB_PREFER_REMOTE=false
# DB_PREFER_REMOTE=false
