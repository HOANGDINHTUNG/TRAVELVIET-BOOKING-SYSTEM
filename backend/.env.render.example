# Copy thành backend/.env.render → điền secret → dán vào Render → Environment
# Render Settings: Health Check Path = /api/v1/live
# Hoặc: Render → Add from .env (chọn file .env.render đã điền)

SPRING_PROFILES_ACTIVE=prod

FLYWAY_ENABLED=false
MINIO_ENABLED=false

# Bắt buộc — Service URI Public từ Aiven (tab Public, ssl-mode=REQUIRED)
MYSQL_SERVICE_URI=

# Thay URI bằng host/port (giữ AIVEN_DB_PASSWORD):
# AIVEN_DB_HOST=
# AIVEN_DB_PORT=
# AIVEN_DB_DATABASE=defaultdb
# AIVEN_DB_USER=avnadmin
AIVEN_DB_PASSWORD=
AIVEN_DB_SSL_MODE=REQUIRED
AIVEN_CA_CERT_PATH=classpath:ssl/ca.pem

JWT_SECRET=

GEMINI_API_KEY=
WEATHERAPI_KEY=

MINIO_URL=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET_NAME=
