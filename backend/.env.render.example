# === IMPORT LÊN RENDER: copy → .env.render → điền secret → Add from .env ===
# Hướng dẫn: backend/docs/RENDER_DEPLOY_STABLE.md
# Dashboard: Health Check Path = /api/v1/live

SPRING_PROFILES_ACTIVE=prod

FLYWAY_ENABLED=false
MINIO_ENABLED=false

MYSQL_SERVICE_URI=mysql://avnadmin:YOUR_AIVEN_DB_PASSWORD@mysql-lab-example.f.aivencloud.com:23132/defaultdb?ssl-mode=REQUIRED

AIVEN_DB_HOST=mysql-lab-example.f.aivencloud.com
AIVEN_DB_PORT=23132
AIVEN_DB_DATABASE=defaultdb
AIVEN_DB_USER=avnadmin
AIVEN_DB_PASSWORD=YOUR_AIVEN_DB_PASSWORD
AIVEN_DB_SSL_MODE=REQUIRED
AIVEN_CA_CERT_PATH=classpath:ssl/ca.pem

JWT_SECRET=YOUR_JWT_SECRET

GEMINI_API_KEY=YOUR_GEMINI_API_KEY
WEATHERAPI_KEY=YOUR_WEATHERAPI_KEY
