# Mẫu biến môi trường Render — copy từng dòng vào Render Dashboard → Environment
# KHÔNG commit file này có password thật.

SPRING_PROFILES_ACTIVE=prod

# Bắt buộc — Render có thể Generate Random Value
JWT_SECRET=thay-bang-chuoi-ngau-nhien-it-nhat-32-ky-tu

# === Database Aiven (chọn Cách A hoặc Cách B) ===

# Cách A — khuyến nghị: dán Service URI (Public) từ Aiven Console
MYSQL_SERVICE_URI=mysql://avnadmin:MAT_KHAU@mysql-ten-service.aivencloud.com:23132/defaultdb?ssl-mode=REQUIRED

# Cách B — nếu không dùng URI, điền từng biến (Public host/port từ Aiven)
# AIVEN_DB_HOST=mysql-ten-service.aivencloud.com
# AIVEN_DB_PORT=23132
# AIVEN_DB_PASSWORD=MAT_KHAU
# AIVEN_DB_USER=avnadmin
# AIVEN_DB_DATABASE=defaultdb

AIVEN_CA_CERT_PATH=classpath:ssl/ca.pem
