# Local dev (profile dev) — host/port trong application-dev.yaml
AIVEN_DB_PASSWORD=
GEMINI_API_KEY=
WEATHERAPI_KEY=

# API failover (Render down → dùng localhost) — xem backend/docs/API_FAILOVER.md
# API_FAILOVER_ENABLED=true
# API_PREFER_PUBLIC=true
# APP_API_PUBLIC_BASE_URL=https://travelviet-booking-system.onrender.com/api/v1
# APP_API_LOCAL_BASE_URL=http://localhost:8088/api/v1

# DB failover — xem backend/docs/DATABASE_FAILOVER.md
# DB_FAILOVER_ENABLED=true
# DB_PREFER_REMOTE=false

# Render (profile prod) — thêm trên Dashboard Render
# JWT_SECRET=
# AIVEN_CA_CERT_PATH=ca.pem
# SPRING_PROFILES_ACTIVE=prod
