# =============================================================================
# backend/.env — dev (mặc định) hoặc prod (SPRING_PROFILES_ACTIVE=prod)
# =============================================================================

# --- Database Aiven (bắt buộc khi DB_PREFER_REMOTE / prod) ---
MYSQL_SERVICE_URI=
AIVEN_DB_HOST=
AIVEN_DB_PORT=
AIVEN_DB_DATABASE=
AIVEN_DB_USER=
AIVEN_DB_PASSWORD=
AIVEN_DB_SSL_MODE=
AIVEN_CA_CERT_PATH=

# --- JWT (prod bắt buộc; dev có thể dùng secret trong application-dev.yaml) ---
JWT_SECRET=

# --- API keys (tùy chọn) ---
GEMINI_API_KEY=
WEATHERAPI_KEY=

# --- API failover dev (2 URL: public | local — default trong yaml nếu không set) ---
API_FAILOVER_ENABLED=
API_PREFER_PUBLIC=
APP_API_PUBLIC_BASE_URL=
APP_API_LOCAL_BASE_URL=

# --- DB failover dev ---
DB_FAILOVER_ENABLED=
DB_PREFER_REMOTE=

# --- Prod / Render thêm ---
SPRING_PROFILES_ACTIVE=
PORT=

# --- Minio prod (tùy chọn) ---
MINIO_URL=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET_NAME=

# --- VNPAY (tùy chọn) ---
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_RETURN_URL=
VNPAY_IPN_URL=

# --- Redis k8s / cache redis (tùy chọn) ---
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=
