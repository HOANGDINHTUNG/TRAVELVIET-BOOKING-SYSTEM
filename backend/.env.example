# Sao chép thành `.env` ở thư mục gốc repo hoặc `backend/.env`.
# Spring import: optional:file:.env và optional:file:backend/.env (xem application.yaml).
# Không commit file `.env` chứa secret thật.

# --- JWT (bắt buộc nếu không dùng placeholder trong application-dev.yaml) ---
JWT_SECRET=your-secret-at-least-32-characters-long-for-hs256
JWT_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=2592000000

# --- MySQL (profile dev) ---
# Access denied ... @'10.0.2.2' → cần wed_app_user@'%'. Chạy: pwsh -File backend/scripts/ensure-mysql-dev-user.ps1
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USERNAME=wed_app_user
DB_PASSWORD=123456

# --- MinIO ---
MINIO_URL=http://127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=tour-images

# --- WeatherAPI.com (tùy — để trống thì client weather trả lỗi cấu hình) ---
WEATHERAPI_BASE_URL=https://api.weatherapi.com/v1
WEATHERAPI_KEY=
WEATHERAPI_FORECAST_DAYS=1
WEATHERAPI_AQI=no
WEATHERAPI_ALERTS=no

# --- Google Gemini (AI chat — tùy) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/models
GEMINI_TIMEOUT=15s

# --- VNPay (sandbox / production — tùy) ---
# Public base URL của API phải khớp ipn-url / return-url (ví dụ https://your-domain/api/v1).
VNPAY_ENABLED=false
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=https://your-frontend/payment/vnpay/return
VNPAY_IPN_URL=https://your-backend/api/v1/payments/vnpay/ipn
VNPAY_LOCALE=vn
VNPAY_ORDER_INFO_PREFIX=TravelViet booking
