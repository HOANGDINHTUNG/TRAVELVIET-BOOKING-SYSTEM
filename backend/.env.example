# =============================================================================
# BACKEND ENVIRONMENT TEMPLATE (.env.example)
# Hướng dẫn: 
# 1. Copy file này thành `.env` (hoặc `.env.local`, `.env.production`)
# 2. KHÔNG bao giờ commit file `.env` chứa mật khẩu thật lên Git!
# =============================================================================

# --- Database MySQL (Aiven hoặc Database Remote khác) ---
# Bắt buộc khi chạy prod (SPRING_PROFILES_ACTIVE=prod) hoặc khi bật DB_PREFER_REMOTE=true ở local
# Đường dẫn tuyệt đối đến file chứng chỉ CA (ví dụ: D:/aiven/ca.pem)

# --- JWT (JSON Web Token) ---
# Bắt buộc cho môi trường production. 
# Ở dev đã có sẵn secret mặc định trong `application-dev.yaml`, nhưng vẫn ưu tiên dùng biến môi trường.
# Đây là chuỗi dùng để ký token. Hãy tạo một chuỗi ngẫu nhiên đủ dài (ít nhất 256 bits / 32 ký tự).
JWT_SECRET=your_super_secret_jwt_key_please_change_this_in_production

# --- Các dịch vụ tích hợp API (Tùy chọn cho dev, bắt buộc khi xài full tính năng) ---
# API Key của Google Gemini cho AI
GEMINI_API_KEY=AIzaSyYourGeminiApiKeyHere_DoNotShare
# API Key của WeatherAPI để lấy thông tin thời tiết
WEATHERAPI_KEY=your_weatherapi_key_here

# --- Cấu hình API Failover & Routing (Cho Frontend biết) ---
# Quy tắc Failover: nếu API cục bộ tạch, có tự động gọi lên API Render hay không?
API_FAILOVER_ENABLED=true
API_PREFER_PUBLIC=false
# Địa chỉ Public API (thường là link deploy Render / Vercel của dự án)
APP_API_PUBLIC_BASE_URL=https://travelviet-booking-system.onrender.com/api/v1
# Địa chỉ API khi chạy mộc ở local
APP_API_LOCAL_BASE_URL=http://localhost:8088/api/v1

# --- Cấu hình DB Failover ---
# Nếu true, sẽ ưu tiên kết nối tới Aiven DB Remote thay vì MySQL local
DB_FAILOVER_ENABLED=false
DB_PREFER_REMOTE=false

# --- Cấu hình Môi trường Spring Boot ---
# Điền "prod" khi deploy lên server, để trống hoặc "dev" khi chạy trên máy tính.
SPRING_PROFILES_ACTIVE=dev
# Port ứng dụng chạy (mặc định 8088 hoặc do server cấp)
PORT=8088

# --- MinIO: Lưu trữ hình ảnh (S3 Compatible) ---
# Bắt buộc nếu dùng tính năng upload hình ảnh lên storage cục bộ
MINIO_URL=http://127.0.0.1:9000
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key
MINIO_BUCKET_NAME=travelviet-bucket

# --- Cổng thanh toán VNPAY (Tùy chọn) ---
# Đăng ký tài khoản Sandbox VNPAY tại: https://sandbox.vnpayment.vn/
VNPAY_TMN_CODE=YOUR_TMN_CODE_HERE
VNPAY_HASH_SECRET=your_vnpay_hash_secret_key_here
VNPAY_RETURN_URL=http://localhost:5173/payment/vnpay-return
VNPAY_IPN_URL=http://localhost:8088/api/v1/payment/vnpay-ipn

# --- Redis Cache ---
# Ở dev thường để rỗng (hoặc chạy 127.0.0.1 nếu bạn đang bật Redis trên máy tính) 
# Ở môi trường k8s/prod thì bắt buộc phải cấu hình.
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_if_any









===============================================================

# # --- Profile ---
# SPRING_PROFILES_ACTIVE=dev

# # --- Aiven MySQL (bắt buộc khi DB_PREFER_REMOTE=true hoặc profile prod) ---

# # --- DB failover (dev: Aiven → fallback MySQL 127.0.0.1:3307) ---
# DB_FAILOVER_ENABLED=true
# DB_PREFER_REMOTE=true

# # --- JWT (bắt buộc trên Render / profile prod) ---
# JWT_SECRET=TravelVietBookingJwtSecretKey2026-Min32Chars-Ok!

# # --- API failover dev: local trước → Render nếu local down ---
# API_FAILOVER_ENABLED=true
# API_PREFER_PUBLIC=false
