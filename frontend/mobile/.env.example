# Copy → .env rồi: npx expo start -c

# URL cố định (tắt failover nếu set URL này):
# EXPO_PUBLIC_API_URL=http://10.0.2.2:8088/api/v1

# Failover dev (giống web): thử local rồi Render
EXPO_PUBLIC_API_FAILOVER_ENABLED=true
EXPO_PUBLIC_API_LOCAL_URL=http://10.0.2.2:8088/api/v1
EXPO_PUBLIC_API_PUBLIC_URL=https://travelviet-booking-system.onrender.com/api/v1

# Điện thoại thật — đặt LOCAL_URL = http://<IP-LAN>:8088/api/v1
