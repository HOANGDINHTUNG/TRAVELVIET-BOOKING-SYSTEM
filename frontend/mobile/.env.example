# =============================================================================
# FRONTEND MOBILE ENVIRONMENT TEMPLATE (.env.example)
# Hướng dẫn: 
# 1. Copy file này thành `.env` (để dùng trong phát triển Expo Local)
# 2. KHÔNG BAO GIỜ commit file `.env` lên Git!
# =============================================================================

# --- TÍNH NĂNG FAILOVER API (Mặc định cho Dev) ---
# Thử kết nối API cục bộ trước, nếu thiết bị không chạy chung mạng LAN với cục bộ (hoặc cục bộ sập)
# sẽ tự động rớt về API Public trên server.
EXPO_PUBLIC_API_FAILOVER_ENABLED=true

# --- CẤU HÌNH API ĐỂ CHẠY TRÊN THIẾT BỊ THẬT / MÁY ẢO ---
# (1) Base URL của API Backend Local:
# LƯU Ý QUAN TRỌNG: 
# - Nếu chạy trên MÁY ẢO Android Emulator trên cùng 1 máy tính: dùng `10.0.2.2` (thay vì localhost)
# - Nếu chạy trên ĐIỆN THOẠI THẬT (cùng mạng Wi-Fi): bắt buộc nhập địa chỉ IPv4 LAN thật của máy tính (vd: 192.168.1.x)
EXPO_PUBLIC_API_LOCAL_URL=http://10.0.2.2:8088/api/v1

# (2) Base URL của API Backend Public (Deploy trên Render hoặc VPS thật)
EXPO_PUBLIC_API_PUBLIC_URL=https://travelviet-booking-system.onrender.com/api/v1

# --- CÁCH TẮT FAILOVER ---
# Nếu muốn gọi trực tiếp 1 cấu hình cứng duy nhất không qua cơ chế failover:
# Xoá/comment các dòng EXPO_PUBLIC_API_FAILOVER_ENABLED và dùng dòng này:
# EXPO_PUBLIC_API_URL=http://192.168.1.100:8088/api/v1
