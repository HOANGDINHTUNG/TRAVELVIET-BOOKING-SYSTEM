{
  "expo": {
    "name": "TravelViet Commerce",
    "slug": "travelviet-commerce",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "travelviet-commerce",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.travelviet.commerce",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Ứng dụng cần quyền truy cập microphone để ghi âm giọng nói và thực hiện tìm kiếm bằng giọng nói.",
        "NSSpeechRecognitionUsageDescription": "Ứng dụng cần quyền nhận dạng giọng nói để chuyển lời nói của bạn thành từ khóa tìm kiếm."
      }
    },
    "android": {
      "package": "com.travelviet.commerce",
      "adaptiveIcon": {
        "backgroundColor": "#F8FAFC",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F8FAFC",
          "dark": {
            "backgroundColor": "#F8FAFC"
          }
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Cho phép ứng dụng sử dụng microphone để ghi âm tìm kiếm bằng giọng nói.",
          "speechRecognitionPermission": "Cho phép ứng dụng nhận diện giọng nói của bạn để thực hiện các tìm kiếm chuẩn xác."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
