# =============================================================================
# FRONTEND WEB PRODUCTION TEMPLATE (.env.production.example)
# Hướng dẫn: 
# Không nên lưu cứng giá trị vào `.env.production` nếu bạn deploy bằng Vercel/Render!
# Hãy lấy nội dung này và cấu hình vào mục "Environment Variables" trên Dashboard của Hosting (Vercel/Render).
# =============================================================================

# Base URL chính xác cho môi trường Production của bạn
VITE_API_BASE_URL=https://your-production-backend.onrender.com/api/v1

# Nếu muốn bật/tắt các feature-flag đặc biệt cho Production:
# VITE_ENABLE_ANALYTICS=true
