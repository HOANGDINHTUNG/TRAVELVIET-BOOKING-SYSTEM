# =============================================================================
# FRONTEND WEB ENVIRONMENT TEMPLATE (.env.example)
# Hướng dẫn: 
# 1. Copy file này thành `.env` (để dùng trong môi trường dev cục bộ)
# 2. KHÔNG BAO GIỜ commit file `.env` lên Git vì có thể làm rò rỉ cấu hình!
# =============================================================================

# --- TÍNH NĂNG FAILOVER API (Mặc định bật ở môi trường Dev) ---
# Failover giúp ứng dụng thử fetch Local API, nếu sập sẽ tự động đổi qua Public API (Render)
# Rất hữu ích khi backend đang chạy nhưng frontend lại gọi một API đang lỗi ở cục bộ.
VITE_API_FAILOVER_ENABLED=true

# --- CẤU HÌNH API URL ---
# (1) Base URL của API Backend Local
VITE_API_LOCAL_BASE_URL=http://localhost:8088/api/v1

# (2) Base URL của API Backend Public (thường là link được deploy trên Render / Vercel)
VITE_API_PUBLIC_BASE_URL=https://travelviet-booking-system.onrender.com/api/v1

# --- CÁCH TẮT FAILOVER (Tuỳ chọn cấu hình URL cố định) ---
# Nếu muốn TẮT hoàn toàn failover và chỉ định cố định một URL duy nhất để gọi (VD: chỉ gọi local):
# VITE_API_FAILOVER_ENABLED=false
# VITE_API_BASE_URL=http://localhost:8088/api/v1

# Nếu muốn ưu tiên chạy Public Render API ngay từ đầu (bỏ qua local):
# VITE_API_PREFER_PUBLIC=true
