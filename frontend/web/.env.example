# URL API backend (KHÁC với DB MySQL port 3307!)
# Copy thành .env rồi restart `npm run dev`.
#
# Failover: thử public trước, không được → http://localhost:8088/api/v1 (mặc định khi `npm run dev`)
# VITE_API_FAILOVER_ENABLED=true
# VITE_API_PREFER_PUBLIC=true
# VITE_API_PUBLIC_BASE_URL=https://travelviet-booking-system.onrender.com/api/v1
# VITE_API_LOCAL_BASE_URL=http://localhost:8088/api/v1
#
# Hoặc chỉ định một URL (bỏ qua probe nếu là localhost):
# VITE_API_BASE_URL=http://localhost:8088/api/v1
#
# Render (đã deploy) — build production:
# VITE_API_BASE_URL=https://travelviet-booking-system.onrender.com/api/v1
VITE_API_BASE_URL=https://travelviet-booking-system.onrender.com/api/v1
